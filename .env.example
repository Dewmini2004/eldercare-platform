# ─── Auth ────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI (Groq) ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ─── Google Maps ─────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Payments (PayHere - Sri Lanka) ──────────────────────
PAYHERE_MERCHANT_ID=your_payhere_merchant_id
PAYHERE_SECRET=your_payhere_secret
PAYHERE_MODE=sandbox   # sandbox | live

# ─── Cloudinary (Image uploads) ──────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Twilio (SMS alerts) ─────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# ─── SMTP (Email notifications) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ────────────────────────────────────────────
RABBITMQ_URL=amqp://eldercare:eldercare123@localhost:5672

# ─── SLNC Nurse Verification ─────────────────────────────
SLNC_VERIFY_URL=https://www.slnc.lk/registered_nurses.php

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3000
